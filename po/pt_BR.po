msgstr "Sair (sessoes ativas)"

#: src/terminal/sk_terminal_dead.c
msgid "This session has ended on the server."
msgstr "Esta sessao foi encerrada no servidor."

#: src/terminal/sk_terminal_dead.c
msgid ""
"The terminal content above is preserved from the session history.\n"
"You can scroll through it and copy text."
msgstr ""
"O conteudo do terminal acima foi preservado do historico da sessao.\n"
"Voce pode rolar e copiar texto."

#: src/terminal/sk_terminal_dead.c
