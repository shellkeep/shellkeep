msgstr "Autenticando..."

#: src/ui/sk_conn_feedback.c
msgid "Checking tmux..."
msgstr "Verificando tmux..."

#: src/ui/sk_conn_feedback.c
msgid "Loading state..."
msgstr "Carregando estado..."

#: src/ui/sk_conn_feedback.c
msgid "Restoring sessions..."
msgstr "Restaurando sessoes..."

#: src/ui/sk_conn_feedback.c
msgid "Connected"
msgstr "Conectado"

#: src/ui/sk_conn_feedback.c
msgid "Connection failed"
msgstr "Falha na conexao"

#. Translators: %1$d is the current session number, %2$d is the total
#: src/ui/sk_conn_feedback.c
#, c-format
msgid "Restoring sessions (%1$d/%2$d)..."
msgstr "Restaurando sessoes (%1$d/%2$d)..."

#: src/ui/sk_toast.c
msgid ""
"Session kept on server \xe2\x80\x94 you can restore it later"
msgstr ""
"Sessao mantida no servidor \xe2\x80\x94 voce pode restaura-la depois"

#: src/ui/sk_toast.c
msgid ""
"shellkeep continues running in the system tray. Your sessions remain active."
msgstr ""
"shellkeep continua rodando na bandeja do sistema. Suas sessoes permanecem ativas."

#: src/ui/sk_app_window.c
msgid "Rename"
msgstr "Renomear"

#: src/ui/sk_app_window.c
