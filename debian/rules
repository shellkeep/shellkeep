#!/usr/bin/make -f
# SPDX-FileCopyrightText: 2026 shellkeep contributors
# SPDX-License-Identifier: GPL-3.0-or-later

# NFR-DIST-02: .deb build rules using Meson
# NFR-DIST-07: Do NOT register as x-terminal-emulator

%:
	dh $@ --buildsystem=meson

override_dh_auto_configure:
	dh_auto_configure -- \
		-Dtests=false \
		-Djournald=enabled

# Hardening flags
export DEB_BUILD_MESON_OPTIONS = --buildtype=release

# NFR-DIST-07: Explicitly do NOT register as x-terminal-emulator.
# shellkeep is not a local terminal — registering it would confuse
# applications that expect a local shell.
# No override_dh_installalternatives is needed because we never
# call update-alternatives.
