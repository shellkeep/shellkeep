#!/usr/bin/env bash
# SPDX-FileCopyrightText: 2026 shellkeep contributors
# SPDX-License-Identifier: GPL-3.0-or-later
#
# Pre-commit hook: clang-format check + SPDX header check on staged .c/.h files.
# Install via: ./scripts/install-hooks.sh

set -euo pipefail

ERRORS=0

# Collect staged .c and .h files (only added/modified, not deleted).
mapfile -t STAGED_FILES < <(
  git diff --cached --name-only --diff-filter=ACM -- '*.c' '*.h'
)

if [[ ${#STAGED_FILES[@]} -eq 0 ]]; then
  exit 0
fi

# --------------------------------------------------------------------------- #
# Check 1: clang-format                                                       #
# --------------------------------------------------------------------------- #

if command -v clang-format &>/dev/null; then
  BAD_FORMAT=()
  for file in "${STAGED_FILES[@]}"; do
    # Compare the staged version against clang-format output.
    if ! git show ":${file}" | clang-format --assume-filename="${file}" \
        | diff -q - <(git show ":${file}") &>/dev/null; then
      BAD_FORMAT+=("${file}")
    fi
  done

  if [[ ${#BAD_FORMAT[@]} -gt 0 ]]; then
    printf '\033[1;31m[pre-commit]\033[0m clang-format violations in:\n'
    for f in "${BAD_FORMAT[@]}"; do
      printf '  %s\n' "${f}"
    done
    printf '\nRun: make format\n\n'
    ERRORS=1
  fi
else
  printf '\033[1;33m[pre-commit]\033[0m clang-format not found — skipping format check.\n'
fi

# --------------------------------------------------------------------------- #
# Check 2: SPDX header                                                        #
# --------------------------------------------------------------------------- #

SPDX_COPYRIGHT="SPDX-FileCopyrightText: 2026 shellkeep contributors"
SPDX_LICENSE="SPDX-License-Identifier: GPL-3.0-or-later"

BAD_SPDX=()
for file in "${STAGED_FILES[@]}"; do
  CONTENT="$(git show ":${file}" | head -5)"
  if ! echo "${CONTENT}" | grep -qF "${SPDX_COPYRIGHT}"; then
    BAD_SPDX+=("${file}")
  elif ! echo "${CONTENT}" | grep -qF "${SPDX_LICENSE}"; then
    BAD_SPDX+=("${file}")
  fi
done

if [[ ${#BAD_SPDX[@]} -gt 0 ]]; then
  printf '\033[1;31m[pre-commit]\033[0m Missing SPDX header in:\n'
  for f in "${BAD_SPDX[@]}"; do
    printf '  %s\n' "${f}"
  done
  printf '\nRequired header (first two lines of every .c/.h file):\n'
  printf '  // %s\n' "${SPDX_COPYRIGHT}"
  printf '  // %s\n' "${SPDX_LICENSE}"
  printf '\n'
  ERRORS=1
fi

# --------------------------------------------------------------------------- #
# Result                                                                       #
# --------------------------------------------------------------------------- #

if [[ ${ERRORS} -ne 0 ]]; then
  printf '\033[1;31m[pre-commit]\033[0m Commit blocked — fix the issues above.\n'
  exit 1
fi

exit 0
